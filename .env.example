# Copy this file to your server environment (or Apache/Nginx env config)
# and set production values.

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fashion_marketplace
DB_USER=fashion_user
DB_PASS=change_me

# Comma-separated CORS allowlist (required when frontend and API are on different origins)
# Example:
# CORS_ALLOWED_ORIGINS=https://marketplace.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=https://marketplace.example.com

# Demo verification behavior:
# 1 = send OTP/token back in API responses (development only)
# 0 = do not expose OTP/token in API responses (production)
ALLOW_DEMO_VERIFICATION=0

# SMS provider configuration (currently supports: twilio)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Email delivery configuration (uses PHP mail())
APP_NAME=FASHION HUB
APP_BASE_URL=https://marketplace.example.com
MAIL_FROM=no-reply@marketplace.example.com

# Admin dashboard key for legitimacy review actions
ADMIN_REVIEW_KEY=change_admin_review_key
